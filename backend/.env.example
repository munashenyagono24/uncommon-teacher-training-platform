# Server configurations
PORT=5000

# Neon PostgreSQL Database Connection String
# Neon requires sslmode=require in the connection URL.
# Replace with your actual database connection string from your Neon dashboard.
DATABASE_URL=postgresql://user:password@ep-something.us-east-2.aws.neon.tech/neondb?sslmode=require

# Clerk API Keys
# Retrieve these from your Clerk Dashboard -> API Keys section.
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
